{
  "name": "@fredrika/mcp-mochi",
  "version": "2.5.0",
  "description": "MCP server for Mochi flashcard integration",
  "main": "dist/index.js",
  "type": "module",
  "bin": {
    "mcp-mochi": "./dist/index.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node-esm src/index.ts",
    "dev:inspect": "npx @modelcontextprotocol/inspector ts-node-esm src/index.ts",
    "test": "jest",
    "prepublishOnly": "npm run build",
    "version:minor": "npm version minor",
    "release:minor": "npm run version:minor && npm publish"
  },
  "keywords": [
    "mcp",
    "mochi",
    "flashcards",
    "spaced-repetition",
    "model-context-protocol"
  ],
  "author": "",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.25.2",
    "axios": "^1.6.7",
    "dotenv": "^16.4.5",
    "form-data": "^4.0.5"
  },
  "devDependencies": {
    "@types/node": "^20.11.24",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  }
}
